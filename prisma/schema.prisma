model Author {
  id    Int     @id @default(autoincrement())
  name  String
  email String? @unique

  // relation field: a single author can have many books
  books Book[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Book {
  id          Int       @id @default(autoincrement())
  title       String
  isbn        String    @unique
  summary     String?
  pages       Int?
  publishedAt DateTime?
  available   Boolean   @default(true)

  // Foreigen Key to author
  author   Author @relation(fields: [authorId], references: [id])
  authorId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}